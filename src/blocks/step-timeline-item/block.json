{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "brilliant/step-timeline-item",
    "version": "1.0.0",
    "title": "Step Timeline Item",
    "category": "brilliant-blocks",
    "description": "Step Timeline Item child block for carousel.",
    "example": {},
    "parent": ["brilliant/step-timeline"],
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "color": {
            "text": false,
            "background": true,
            "gradients": true
        },
        "background": {
            "backgroundImage": true,
            "backgroundSize": true
        },
        "spacing": {
            "margin": false,
            "padding": true,
            "__experimentalDefaultControls": {
                "padding": false
            }
        },
        "__experimentalBorder": {
            "__experimentalSkipSerialization": false,
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "shadow": {
            "__experimentalSkipSerialization": true
        }
    },
    "attributes": {
        "title": {
            "type": "string",
            "default": "Step Title"
        },
        "description": {
            "type": "string",
            "default": "Step description goes here."
        },
        "headingTag": {
            "type": "string",
            "default": "h3"
        },
        "titleColor": {
            "type": "string"
           
        },
        "descriptionColor": {
            "type": "string"
           
        }
    },
    "textdomain": "brilliant",
    "editorScript": ["file:./index.js"]
}
