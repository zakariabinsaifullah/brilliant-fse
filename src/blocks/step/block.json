{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "brilliant/step",
    "version": "1.0.0",
    "title": "Step",
    "category": "brilliant-blocks",
    "description": "A single step item — child of the Steps block.",
    "example": {},
    "parent": ["brilliant/steps"],
    "supports": {
        "html":      false,
        "reusable":  false,
        "inserter":  false
    },
    "attributes": {
        "stepNumber": {
            "type":    "string",
            "default": "01"
        },
        "iconName": {
            "type":    "string",
            "default": "wordpress"
        },
        "iconType": {
            "type":    "string",
            "default": "line"
        },
        "customSvgCode": {
            "type": "string"
        },
        "strokeWidth": {
            "type":    "number",
            "default": 1.2
        },
        "title": {
            "type": "string"
        },
        "titleTag": {
            "type":    "string",
            "default": "h3"
        },
        "description": {
            "type": "string"
        },
        "showArrow": {
            "type":    "boolean",
            "default": true
        }
    },
    "textdomain": "brilliant",
    "editorScript": "file:./index.js",
    "style":        "file:./style-index.css"
}
